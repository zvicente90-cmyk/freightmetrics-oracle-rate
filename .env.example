# ============================================
# FreightMetrics MVP - Environment Variables
# ============================================
# Copiar este archivo a .env y llenar con valores reales
# Nunca commitear .env a GitHub

# Google APIs - Requerir obtener en Google Cloud Console
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Configuración de la Aplicación
STREAMLIT_PORT=8501
FASTAPI_PORT=8000
DEBUG=False

# Base de datos (SQLite por defecto)
DATABASE_URL=sqlite:///freightmetrics.db

# Firebase (Opcional - si usas autenticación con Firebase)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Configuración de Email (Opcional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Rutas de datos
DATA_DIR=./data
MODELS_DIR=./models
LOGS_DIR=./logs
